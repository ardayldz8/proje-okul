generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TEACHER
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum TestStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum AttemptStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum OtpPurpose {
  STUDENT_TEST_START
  STUDENT_PORTAL_LOGIN
  PASSWORD_RESET
}

enum AdPlacement {
  HOME
  COURSE_LIST
  RESULT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  fullName     String
  email        String   @unique
  passwordHash String
  role         UserRole
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownedQuestions   Question[]       @relation("QuestionOwner")
  ownedTests       Test[]           @relation("TestOwner")
  teacherStudents  TeacherStudent[] @relation("TeacherStudents")
  assignedStudents TeacherStudent[] @relation("AssignedBy")

  @@index([role])
  @@index([isActive])
}

model Student {
  id         String   @id @default(cuid())
  fullName   String
  email      String   @unique
  passwordHash String?
  phone      String?
  gradeLevel String
  schoolName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  teacherStudents TeacherStudent[]
  attempts        TestAttempt[]
}

model OtpVerification {
  id           String     @id @default(cuid())
  email        String
  codeHash     String
  purpose      OtpPurpose
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int        @default(0)
  createdAt    DateTime   @default(now())

  @@index([email, purpose])
  @@index([expiresAt])
}

model TeacherStudent {
  id         String   @id @default(cuid())
  teacherId  String
  studentId  String
  assignedBy String?
  assignedAt DateTime @default(now())
  note       String?

  teacher  Profile  @relation("TeacherStudents", fields: [teacherId], references: [id], onDelete: Cascade)
  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assigner Profile? @relation("AssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@unique([teacherId, studentId])
  @@index([studentId])
  @@index([assignedBy])
}

model Course {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String?
  iconName     String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  questions Question[]
  tests     Test[]

  @@index([isActive, displayOrder])
}

model Question {
  id             String     @id @default(cuid())
  courseId       String
  ownerTeacherId String
  questionText   String     @db.Text
  optionA        String
  optionB        String
  optionC        String
  optionD        String
  correctOption  String
  difficulty     Difficulty @default(MEDIUM)
  topic          String?
  explanation    String?    @db.Text
  imageUrl       String?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  course        Course          @relation(fields: [courseId], references: [id], onDelete: Restrict)
  ownerTeacher  Profile         @relation("QuestionOwner", fields: [ownerTeacherId], references: [id], onDelete: Restrict)
  testQuestions TestQuestion[]
  answers       StudentAnswer[]

  @@index([courseId])
  @@index([ownerTeacherId])
  @@index([difficulty])
  @@index([isActive])
}

model Test {
  id                     String     @id @default(cuid())
  courseId               String
  ownerTeacherId         String
  title                  String
  description            String?
  durationMinutes        Int?
  status                 TestStatus @default(DRAFT)
  showResultImmediately  Boolean    @default(true)
  requiresStudentAccount Boolean    @default(false)
  startsAt               DateTime?
  endsAt                 DateTime?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  course        Course         @relation(fields: [courseId], references: [id], onDelete: Restrict)
  ownerTeacher  Profile        @relation("TestOwner", fields: [ownerTeacherId], references: [id], onDelete: Restrict)
  testQuestions TestQuestion[]
  attempts      TestAttempt[]

  @@index([courseId])
  @@index([ownerTeacherId])
  @@index([status])
  @@index([startsAt, endsAt])
}

model TestQuestion {
  id         String   @id @default(cuid())
  testId     String
  questionId String
  orderIndex Int
  points     Int      @default(1)
  createdAt  DateTime @default(now())

  test     Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@unique([testId, questionId])
  @@unique([testId, orderIndex])
  @@index([questionId])
}

model TestAttempt {
  id                String        @id @default(cuid())
  testId            String
  studentId         String
  status            AttemptStatus @default(IN_PROGRESS)
  startedAt         DateTime      @default(now())
  completedAt       DateTime?
  durationSeconds   Int?
  score             Float?
  correctCount      Int           @default(0)
  wrongCount        Int           @default(0)
  emptyCount        Int           @default(0)
  ipAddress         String?
  userAgent         String?       @db.Text
  kvkkAcceptedAt    DateTime?
  privacyAcceptedAt DateTime?
  termsAcceptedAt   DateTime?
  createdAt         DateTime      @default(now())

  test    Test            @relation(fields: [testId], references: [id], onDelete: Restrict)
  student Student         @relation(fields: [studentId], references: [id], onDelete: Restrict)
  answers StudentAnswer[]

  @@unique([testId, studentId])
  @@index([studentId])
  @@index([status])
  @@index([startedAt])
}

model StudentAnswer {
  id                    String   @id @default(cuid())
  attemptId             String
  questionId            String
  selectedOption        String?
  isCorrect             Boolean  @default(false)
  answeredAt            DateTime @default(now())
  questionTextSnapshot  String?  @db.Text
  optionASnapshot       String?
  optionBSnapshot       String?
  optionCSnapshot       String?
  optionDSnapshot       String?
  correctOptionSnapshot String?
  explanationSnapshot   String?  @db.Text

  attempt  TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@unique([attemptId, questionId])
  @@index([questionId])
}

model Ad {
  id          String      @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  targetUrl   String?
  placement   AdPlacement
  isActive    Boolean     @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([placement, isActive])
  @@index([startsAt, endsAt])
}
